---
import Layout from "@/layouts/Layout.astro";

const pageTitle       = ["照屋 宏哉 | Portfolio", "照屋 宏哉 | Portfolio"];
const pageDescription = ["フロントエンド実装、CMS連携、静的サイト構築を中心に、Web制作の現場を支える照屋宏哉のポートフォリオです。", "フロントエンド実装、CMS連携、静的サイト構築を中心に、Web制作の現場を支える照屋宏哉のポートフォリオです。"];
const pageBodyClass   = "page-home";

const profileFacts = [
  ["Name", "照屋 宏哉"],
  ["Born", "1981年生まれ"],
  ["Interest", "バイク、釣り、ガーデニング、ゲーム、自作PC、DIY"],
];

const strengths = [
  "Web制作会社でディレクション、デザイン、HTMLコーディングを横断して担当。",
  "ASPの立ち上げ経験を経て、フロントエンドとバックエンドをつなぐJSerとして実装を推進。",
  "AstroやWordPressのヘッドレス化など、運用制約をふまえた静的サイト構築が得意。",
];

const skillGroups = [
  {
    title: "Markup / Styling",
    skills: [
      ["HTML5", true],
      ["Pug", true],
      ["CSS", false],
      ["SCSS", false],
      ["Sass", false],
      ["Stylus", true],
    ],
  },
  {
    title: "Design Tools",
    skills: [
      ["Photoshop", true],
      ["XD", false],
      ["Figma", false],
      ["Illustrator", false],
    ],
  },
  {
    title: "JavaScript / Framework",
    skills: [
      ["JavaScript", true],
      ["TypeScript", false],
      ["CoffeeScript", false],
      ["Next.js", false],
      ["Nuxt.js", false],
      ["Astro", true],
      ["Node.js", false],
    ],
  },
  {
    title: "CMS / Backend / Data",
    skills: [
      ["PHP", false],
      ["Smarty", false],
      ["WordPress", true],
      ["Movable Type", true],
      ["microCMS", false],
      ["Contentful", false],
      ["GraphQL", true],
      ["MySQL", false],
    ],
  },
  {
    title: "Infrastructure / Workflow",
    skills: [
      ["Apache", true],
      ["Nginx", true],
      ["Git", false],
      ["GitHub", false],
      ["GitHub Actions", false],
      ["Bitbucket", false],
      ["SVN", false],
      ["Sourcetree", false],
      ["Slack", false],
    ],
  },
  {
    title: "Animation / Build / Editor",
    skills: [
      ["GSAP", true],
      ["Swiper", true],
      ["Swup", true],
      ["Gulp", false],
      ["Grunt", false],
      ["Sublime Text", false],
      ["IntelliJ IDEA", false],
      ["VS Code", false],
    ],
  },
];

const works = [
  {
    title: "京都能力開発短期大学校",
    url: "https://www3.jeed.go.jp/kyoto/college/",
    role: "サイトリニューアル / CMS連携 / JavaScript実装",
    text: "本番環境にWordPressを設置できない制約に対し、外部WordPressをヘッドレスCMSとして運用する構成を設計。差分データとフルデータを取得できる専用ダウンロードAPI、GitHub Actionsによる静的ファイルのデプロイ導線、アニメーションを含むJavaScript実装を担当しました。",
    tools: ["Astro", "JavaScript", "Stylus", "PHP", "GitHub Actions", "Figma", "WordPress"],
  },
  {
    title: "メジナビ",
    url: "https://www.mejiro.ac.jp/univ/mejinavi2026/",
    role: "大学プロモーションサイト / アニメーション / 画面遷移",
    text: "Swupを使ったシームレスなページ遷移と、サイト全体のアニメーションを実装。描画オブジェクトが多い画面でもスマートフォンで重くなりにくいよう、一部を除いてCSSアニメーションへ置き換え、体験と軽量化のバランスを調整しました。",
    tools: ["Astro", "JavaScript", "Stylus", "Figma"],
  },
  {
    title: "NIKKE バイオハザードコラボ LP",
    url: "http://toys--nikke-biohazard--main.repo.testup.me/",
    role: "LP / JavaScript / API / Canvas生成",
    text: "JS全般とAPIを担当。フォーム入力による簡易謎解きゲーム、クリア人数に応じた合成壁紙のダウンロード機能を実装しました。生成AIではなくCanvasで画像を合成する方式を提案し、統計管理にはクライアントが確認しやすいスプレッドシートを簡易DBとして活用しました。",
    tools: ["Astro", "JavaScript", "Stylus", "Figma", "Spreadsheet", "AWS"],
    note: "公開終了 / Basic認証: ID a、Password 123",
  },
];
---
<Layout pageTitle={pageTitle} pageDescription={pageDescription} pageBodyClass={pageBodyClass}>
  <section class="hero" aria-labelledby="hero-title">
    <p class="hero__eyebrow">Front-end Developer / JSer</p>
    <h1 id="hero-title" class="hero__title">照屋 宏哉</h1>
    <p class="hero__lead">
      Web制作の現場で、ディレクション、デザイン、コーディング、CMS連携を横断してきました。
      制約のある環境でも、運用しやすく軽いサイトへ落とし込むことを得意としています。
    </p>
    <div class="hero__actions">
      <a class="button" href="#works">実績を見る</a>
      <a class="button button--plain" href="#skills">スキルを見る</a>
    </div>
  </section>

  <section id="profile" class="section profile" aria-labelledby="profile-title">
    <div class="section__head">
      <p class="section__kicker">Profile</p>
      <h2 id="profile-title" class="section__title">プロフィール</h2>
    </div>
    <div class="profile__grid">
      <div class="profile__text">
        <p>
          新卒で中小企業のWeb制作・運用会社に入社して以来、会社や立場を変えながらWeb制作に携わってきました。
          ディレクター、Webデザイナー、HTMLコーダーを並行して担当し、アフィリエイトサービスプロバイダの立ち上げにも参加。
        </p>
        <p>
          その後は主にJSerとして、バックエンドとフロントエンドの間をつなぐ実装を担当しています。
          要件や運用条件を整理し、現場で扱いやすい形に実装することを大切にしています。
        </p>
      </div>
      <dl class="facts">
        {profileFacts.map(([label, value]) => (
          <div>
            <dt>{label}</dt>
            <dd>{value}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <section class="section section--muted" aria-labelledby="strength-title">
    <div class="section__head">
      <p class="section__kicker">Strength</p>
      <h2 id="strength-title" class="section__title">できること</h2>
    </div>
    <ul class="strength-list">
      {strengths.map((strength) => <li>{strength}</li>)}
    </ul>
  </section>

  <section id="skills" class="section" aria-labelledby="skills-title">
    <div class="section__head">
      <p class="section__kicker">Skills</p>
      <h2 id="skills-title" class="section__title">スキル・使用ツール</h2>
      <p class="section__note">☆は特に得意なものです。</p>
    </div>
    <div class="skill-grid">
      {skillGroups.map((group) => (
        <section class="skill-group" aria-labelledby={`skill-${group.title.replaceAll(" ", "-").replaceAll("/", "-").toLowerCase()}`}>
          <h3 id={`skill-${group.title.replaceAll(" ", "-").replaceAll("/", "-").toLowerCase()}`}>{group.title}</h3>
          <ul>
            {group.skills.map(([skill, featured]) => (
              <li class:list={{ "is-featured": featured }}>
                <span>{skill}</span>
                {featured && <span aria-label="特に得意">☆</span>}
              </li>
            ))}
          </ul>
        </section>
      ))}
    </div>
  </section>

  <section id="works" class="section section--muted" aria-labelledby="works-title">
    <div class="section__head">
      <p class="section__kicker">Works</p>
      <h2 id="works-title" class="section__title">直近の実績</h2>
    </div>
    <div class="works__list">
      {works.map((work) => (
        <article class="work-item">
          <p class="work-item__role">{work.role}</p>
          <h3 class="work-item__title">
            <a href={work.url} target="_blank" rel="noreferrer">{work.title}</a>
          </h3>
          <p class="work-item__text">{work.text}</p>
          {work.note && <p class="work-item__note">{work.note}</p>}
          <ul class="tag-list" aria-label={`${work.title} 使用スキル`}>
            {work.tools.map((tool) => <li>{tool}</li>)}
          </ul>
        </article>
      ))}
    </div>
  </section>
</Layout>
