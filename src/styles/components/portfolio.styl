.wrapper
  min-height 100vh
  background #fbfaf7

.main
  width 100%

.site-header
  position sticky
  z-index 10
  top 0
  display flex
  align-items center
  justify-content space-between
  gap 20px
  width 100%
  padding 16px 20px
  color #202020
  background rgba(251, 250, 247, .92)
  border-bottom 1px solid #e4e0d8
  backdrop-filter blur(12px)
  +media('md')
    padding 18px 48px

.site-header__brand
  display inline-flex
  align-items baseline
  gap 10px
  flex 0 0 auto
  color #202020
  font-pixel(15, 15)
  font-weight 700

.site-header__mark
  color #8a3b2d

.site-header__name
  color #202020

.site-header__nav
  display none
  align-items center
  gap 22px
  color #5d5b56
  font-pixel(13, 13)
  +media('md')
    display flex

.site-header__nav a
  transition color .2s $ease-sine-out

.site-header__nav a:hover
  color #8a3b2d

.site-footer
  display flex
  flex-direction column
  gap 8px
  padding 28px 20px
  color #5d5b56
  background #f0ede6
  border-top 1px solid #e4e0d8
  +media('md')
    flex-direction row
    align-items center
    justify-content space-between
    padding 32px 48px

.site-footer__name
  color #202020
  font-pixel(15, 15)
  font-weight 700

.site-footer__copy
  max-width 560px
  font-pixel(13, 22)

.hero
  max-width 1080px
  margin 0 auto
  padding 96px 20px 70px
  color #202020
  +media('md')
    padding 138px 48px 108px

.hero__eyebrow,
.section__kicker
  color #8a3b2d
  font-pixel(12, 12)
  font-weight 700
  text-transform uppercase
  letter-spacing .08em

.hero__title
  margin-top 18px
  font-pixel(48, 56)
  font-weight 800
  letter-spacing 0
  +media('md')
    font-pixel(76, 86)

.hero__lead
  max-width 760px
  margin-top 22px
  color #45433f
  font-pixel(16, 30)
  +media('md')
    font-pixel(18, 34)

.hero__actions
  display flex
  flex-wrap wrap
  gap 12px
  margin-top 30px

.button
  display inline-flex
  align-items center
  justify-content center
  min-height 44px
  padding 0 18px
  color #fbfaf7
  background #202020
  border 1px solid #202020
  border-radius 4px
  font-pixel(14, 14)
  font-weight 700
  transition background .2s $ease-sine-out, color .2s $ease-sine-out, border-color .2s $ease-sine-out

.button:hover
  color #202020
  background transparent

.button--plain
  color #202020
  background transparent

.button--plain:hover
  color #fbfaf7
  background #202020

.section
  padding 64px 20px
  border-top 1px solid #e4e0d8
  +media('md')
    padding 88px 48px

.section--muted
  background #f5f2ec

.section__head
  max-width 1080px
  margin 0 auto 28px

.section__title
  margin-top 12px
  color #202020
  font-pixel(28, 36)
  font-weight 800
  +media('md')
    font-pixel(40, 50)

.section__note
  margin-top 12px
  color #5d5b56
  font-pixel(14, 24)

.profile__grid
  display grid
  gap 28px
  max-width 1080px
  margin 0 auto
  +media('md')
    grid-template-columns minmax(0, 1fr) 340px
    gap 58px

.profile__text
  display grid
  gap 18px
  color #45433f
  font-pixel(15, 29)
  +media('md')
    font-pixel(16, 32)

.facts
  display grid
  align-self start
  border-top 1px solid #d7d1c6

.facts div
  display grid
  gap 6px
  padding 16px 0
  border-bottom 1px solid #d7d1c6

.facts dt
  color #8a3b2d
  font-pixel(12, 12)
  font-weight 700
  text-transform uppercase
  letter-spacing .06em

.facts dd
  color #202020
  font-pixel(14, 24)

.strength-list
  display grid
  gap 0
  max-width 1080px
  margin 0 auto
  border-top 1px solid #d7d1c6

.strength-list li
  padding 18px 0
  color #30302d
  border-bottom 1px solid #d7d1c6
  font-pixel(15, 28)
  +media('md')
    font-pixel(17, 31)

.skill-grid
  display grid
  gap 16px
  max-width 1080px
  margin 0 auto
  +media('md')
    grid-template-columns repeat(2, minmax(0, 1fr))

.skill-group
  padding 22px
  background #fff
  border 1px solid #e4e0d8
  border-radius 6px

.skill-group h3
  color #202020
  font-pixel(18, 24)
  font-weight 800

.skill-group ul
  display flex
  flex-wrap wrap
  gap 8px
  margin-top 16px

.skill-group li
  display inline-flex
  align-items center
  gap 5px
  min-height 32px
  padding 0 10px
  color #45433f
  background #f5f2ec
  border 1px solid #ebe5da
  border-radius 4px
  font-pixel(13, 13)

.skill-group li.is-featured
  color #202020
  background #fff7df
  border-color #dfc878
  font-weight 700

.works__list
  display grid
  gap 0
  max-width 1080px
  margin 0 auto
  border-top 1px solid #d7d1c6

.work-item
  display grid
  gap 18px
  padding 28px 0
  border-bottom 1px solid #d7d1c6
  +media('md')
    padding 36px 0

.work-item--has-thumb
  +media('md')
    grid-template-columns 280px minmax(0, 1fr)
    gap 28px
    align-items start

.work-item__thumb
  overflow hidden
  aspect-ratio 16 / 10
  background #ebe5da
  border 1px solid #e4e0d8
  border-radius 6px

.work-item__thumb img
  display block
  width 100%
  height 100%
  object-fit cover

.work-item__role
  color #8a3b2d
  font-pixel(13, 22)
  font-weight 700

.work-item__title
  margin-top 8px
  color #202020
  font-pixel(24, 32)
  font-weight 800
  +media('md')
    font-pixel(30, 38)

.work-item__title a
  text-decoration underline
  text-decoration-thickness 1px
  text-underline-offset 5px

.work-item__text
  max-width 920px
  margin-top 14px
  color #45433f
  font-pixel(15, 29)
  +media('md')
    font-pixel(16, 31)

.work-item__note
  margin-top 10px
  color #716d65
  font-pixel(13, 22)

.tag-list
  display flex
  flex-wrap wrap
  gap 8px
  margin-top 18px

.tag-list li
  padding 7px 10px
  color #30302d
  background #fff
  border 1px solid #e4e0d8
  border-radius 4px
  font-pixel(12, 12)
  font-weight 700

@media only screen and (max-width: 374px)
  .hero__title
    font-pixel(42, 50)

  .section__title
    font-pixel(26, 34)
