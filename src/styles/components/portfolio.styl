.wrapper
  min-height 100vh
  overflow hidden
  background #f7f3ea

.main
  width 100%

.site-header
  position fixed
  z-index 10
  top 0
  left 0
  display flex
  align-items center
  justify-content space-between
  gap 24px
  width 100%
  padding 18px 22px
  color #17201c
  background rgba(247, 243, 234, .82)
  border-bottom 1px solid rgba(23, 32, 28, .1)
  backdrop-filter blur(16px)
  +media('md')
    padding 22px 48px

.site-header__brand
  display inline-flex
  align-items center
  gap 10px
  flex 0 0 auto
  font-weight 700

.site-header__mark
  display grid
  place-items center
  size 38
  color #f7f3ea
  background #17201c
  border-radius 50%
  font-pixel(12, 12)

.site-header__name
  font-pixel(14, 14)

.site-header__nav
  display none
  align-items center
  gap 24px
  color #536058
  font-pixel(13, 13)
  +media('md')
    display flex

.site-header__nav a
  transition color .2s $ease-sine-out

.site-header__nav a:hover
  color #17201c

.site-footer
  display flex
  flex-direction column
  gap 10px
  padding 34px 22px
  color #f7f3ea
  background #17201c
  +media('md')
    flex-direction row
    align-items center
    justify-content space-between
    padding 42px 48px

.site-footer__name
  font-pixel(18, 18)
  font-weight 700

.site-footer__copy
  max-width 520px
  color rgba(247, 243, 234, .72)
  font-pixel(13, 22)

.hero
  display grid
  gap 40px
  min-height 720px
  padding 132px 22px 74px
  color #17201c
  background linear-gradient(180deg, #f7f3ea 0%, #f1e7d6 100%)
  +media('md')
    grid-template-columns minmax(0, 1fr) minmax(420px, 46%)
    align-items center
    gap 56px
    min-height 760px
    padding 140px 48px 88px

.hero__content
  max-width 780px

.hero__eyebrow,
.section__kicker
  color #b35a44
  font-pixel(12, 12)
  font-weight 700
  text-transform uppercase
  letter-spacing .12em

.hero__title
  max-width 860px
  margin-top 20px
  font-pixel(42, 52)
  font-weight 800
  letter-spacing 0
  +media('md')
    font-pixel(72, 84)

.hero__text
  max-width 640px
  margin-top 24px
  color #536058
  font-pixel(16, 30)
  +media('md')
    font-pixel(18, 34)

.hero__actions
  display flex
  flex-wrap wrap
  gap 12px
  margin-top 34px

.button
  display inline-flex
  align-items center
  justify-content center
  min-height 48px
  padding 0 22px
  border 1px solid #17201c
  border-radius 4px
  font-pixel(14, 14)
  font-weight 700
  transition transform .2s $ease-sine-out, background .2s $ease-sine-out, color .2s $ease-sine-out

.button:hover
  transform translateY(-2px)

.button--primary
  color #f7f3ea
  background #17201c

.button--ghost
  color #17201c
  background transparent

.hero__visual
  position relative
  min-height 360px
  +media('md')
    min-height 520px

.browser
  position relative
  overflow hidden
  width 100%
  max-width 620px
  margin-left auto
  background #fffaf1
  border 1px solid rgba(23, 32, 28, .18)
  border-radius 8px
  box-shadow 0 30px 90px rgba(23, 32, 28, .18)

.browser__bar
  display flex
  gap 8px
  padding 16px
  border-bottom 1px solid rgba(23, 32, 28, .12)

.browser__bar span
  size 10
  border-radius 50%
  background #b35a44

.browser__bar span:nth-child(2)
  background #d6a33d

.browser__bar span:nth-child(3)
  background #2e7d73

.browser__screen
  display grid
  gap 18px
  padding 26px

.browser__nav
  width 48%
  height 14px
  background #17201c
  border-radius 2px

.browser__headline
  width 78%
  height 110px
  background #2e7d73
  border-radius 6px

.browser__grid
  display grid
  grid-template-columns repeat(3, 1fr)
  gap 12px

.browser__grid span
  display block
  height 98px
  background #ead2b4
  border-radius 6px

.browser__grid span:nth-child(2)
  background #d98a6c

.browser__grid span:nth-child(3)
  background #17201c

.browser__panel
  height 130px
  background-color #f1e7d6
  background-image linear-gradient(90deg, rgba(46, 125, 115, .22) 0%, rgba(46, 125, 115, .22) 50%, rgba(179, 90, 68, .2) 50%, rgba(179, 90, 68, .2) 100%)
  background-size 48px 100%
  border-radius 6px

.section
  padding 78px 22px
  +media('md')
    padding 110px 48px

.section__head
  display flex
  flex-direction column
  gap 14px
  max-width 1180px
  margin 0 auto 34px
  +media('md')
    margin-bottom 48px

.section__title
  color #17201c
  font-pixel(32, 40)
  font-weight 800
  +media('md')
    font-pixel(48, 58)

.section--intro
  background #fffaf1

.intro
  display grid
  gap 24px
  max-width 1180px
  margin 0 auto
  +media('md')
    grid-template-columns minmax(0, .9fr) minmax(320px, .55fr)
    align-items start
    gap 64px

.intro__title
  color #17201c
  font-pixel(30, 42)
  font-weight 800
  +media('md')
    font-pixel(46, 60)

.intro__text
  color #536058
  font-pixel(16, 30)

.works
  background #f7f3ea

.works__list
  display grid
  gap 20px
  max-width 1180px
  margin 0 auto
  +media('md')
    grid-template-columns repeat(3, minmax(0, 1fr))

.work-card
  overflow hidden
  background #fffaf1
  border 1px solid rgba(23, 32, 28, .12)
  border-radius 8px

.work-card__visual
  padding 18px
  background #ead2b4

.work-card--teal .work-card__visual
  background #bdd8d1

.work-card--coral .work-card__visual
  background #eec4ad

.work-card--ink .work-card__visual
  background #c7c4b9

.mockup
  display grid
  grid-template-columns 1fr 1fr
  gap 10px
  aspect-ratio 4 / 3
  padding 16px
  background #fffaf1
  border-radius 6px

.mockup span
  display block
  border-radius 4px
  background rgba(23, 32, 28, .16)

.mockup__hero
  grid-column 1 / -1
  background #17201c !important

.mockup__line
  height 12px

.mockup__line--wide
  grid-column 1 / -1
  width 70%

.mockup__thumb
  min-height 54px
  background #2e7d73 !important

.work-card__body
  padding 24px

.work-card__type
  color #b35a44
  font-pixel(12, 12)
  font-weight 700

.work-card__title
  margin-top 12px
  color #17201c
  font-pixel(22, 28)
  font-weight 800

.work-card__lead
  margin-top 12px
  color #536058
  font-pixel(14, 24)

.tag-list
  display flex
  flex-wrap wrap
  gap 8px
  margin-top 18px

.tag-list li
  padding 7px 10px
  color #17201c
  background #f1e7d6
  border-radius 3px
  font-pixel(11, 11)
  font-weight 700

.services
  background #fffaf1

.services__list
  display grid
  max-width 1180px
  margin 0 auto
  border-top 1px solid rgba(23, 32, 28, .14)

.service-item
  display grid
  gap 12px
  padding 28px 0
  border-bottom 1px solid rgba(23, 32, 28, .14)
  +media('md')
    grid-template-columns 100px minmax(220px, .4fr) minmax(0, 1fr)
    align-items start
    gap 28px

.service-item__number
  color #b35a44
  font-pixel(13, 13)
  font-weight 700

.service-item__title
  color #17201c
  font-pixel(24, 30)
  font-weight 800

.service-item__text
  color #536058
  font-pixel(15, 28)

.profile
  display grid
  gap 34px
  padding 78px 22px
  color #f7f3ea
  background #17201c
  +media('md')
    grid-template-columns 360px minmax(0, 720px)
    align-items center
    justify-content center
    gap 70px
    padding 110px 48px

.profile__media
  display grid
  place-items center
  aspect-ratio 1
  max-width 280px
  background #2e7d73
  border-radius 8px
  +media('md')
    max-width none

.profile__initial
  color #fffaf1
  font-pixel(120, 120)
  font-weight 800

.profile__title
  margin-top 16px
  font-pixel(30, 42)
  font-weight 800
  +media('md')
    font-pixel(44, 58)

.profile__text
  margin-top 20px
  color rgba(247, 243, 234, .76)
  font-pixel(15, 29)

.profile__facts
  display grid
  gap 14px
  margin-top 28px

.profile__facts div
  display grid
  gap 6px
  padding-top 14px
  border-top 1px solid rgba(247, 243, 234, .18)

.profile__facts dt
  color #d98a6c
  font-pixel(12, 12)
  font-weight 700

.profile__facts dd
  color #fffaf1
  font-pixel(14, 22)

.contact
  padding 78px 22px
  text-align center
  background #f1e7d6
  +media('md')
    padding 110px 48px

.contact .section__kicker
  justify-content center

.contact__title
  max-width 820px
  margin 16px auto 0
  color #17201c
  font-pixel(32, 42)
  font-weight 800
  +media('md')
    font-pixel(50, 64)

.contact__text
  max-width 560px
  margin 18px auto 28px
  color #536058
  font-pixel(15, 28)

@media only screen and (max-width: 374px)
  .hero__title
    font-pixel(34, 44)

  .section__title,
  .contact__title
    font-pixel(28, 38)
